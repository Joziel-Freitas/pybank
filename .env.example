# ==============================================================================
# PyBank Environment Variables Template
#
# INSTRUCTIONS:
# 1. Copy this file and rename it to '.env' (do not commit the actual .env file)
# 2. Fill in the values for your local or production environment.
# ==============================================================================

# ------------------------------------------------------------------------------
# Database Initialization (Docker)
# Used by the MySQL container on first startup to create the schema and users.
# ------------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=insert_root_password_here
MYSQL_DATABASE=pybank
MYSQL_USER=insert_db_user_here
MYSQL_PASSWORD=insert_db_password_here

# ------------------------------------------------------------------------------
# Application Database Connection
# Used by PyMySQL in the Anti-Corruption Layer to connect to the database.
# ------------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306

# ------------------------------------------------------------------------------
# PyBank Core Domain Configurations
# ------------------------------------------------------------------------------
# The commercial name of the Bank displayed in the terminal UI
BANK_NAME="PyBank S.A."

# The 4-digit code identifying the home branch
BRANCH_CODE=0001

# Cryptographic key for hashing passwords and securing AccessTokens (HMAC)
# Must be a long, unpredictable secure string in production.
BANK_SECRET_KEY=insert_your_secret_hash_key_here

# The secret numeric code used to safely shutdown the Kiosk terminal loop
PYBANK_ADMIN_CODE=999999

# Maximum allowed idle time (in seconds) before killing a user session
SYSTEM_TIMEOUT=30.0
